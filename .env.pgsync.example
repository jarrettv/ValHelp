# Copy to .env.pgsync and fill values.
#
# Example Supabase URL format:
# postgres://user:password@host:port/dbname?sslmode=require

PGSYNC_FROM_URL=
PGSYNC_TO_URL=

# Optional scheduling tweaks
# PGSYNC_INTERVAL_SECONDS=14400


# Set to 1 to run once and exit (useful for Task Scheduler)
# RUN_ONCE=0
